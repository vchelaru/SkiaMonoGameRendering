@page "/"
@page "/index.html"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Skia + KNI WebGL</PageTitle>

<main id="game-shell">
    <canvas id="theCanvas" tabindex="0" aria-label="Skia KNI WebGL sample"></canvas>
    <aside id="diagnostics" aria-live="polite">
        <span id="diagnostic-text">@_status</span>
        <select id="upload-mode" aria-label="Upload path">
            <option value="sub">texSubImage2D</option>
            <option value="image">texImage2D diagnostic</option>
        </select>
    </aside>
</main>

<SkiaMonoGameWebGlHost @ref="_skiaHost" RequireWebGl2="true" />
