+        void IBrowserCanvasTextureUploadStrategy.UploadFromCanvas(
+            BrowserCanvasSource source, CanvasUploadOptions options)
+        {
+            var context = ((IPlatformGraphicsContext)base.GraphicsDeviceStrategy.CurrentContext)
+                .Strategy.ToConcrete<ConcreteGraphicsContext>();
+            var GL = context.GL;
+
+            if (GL.IsContextLost())
+                throw new InvalidOperationException("The WebGL context is lost.");
+            if (_glTexture == null)
+                throw new ObjectDisposedException(nameof(ConcreteTexture2D));
+
+            ((IPlatformTextureCollection)base.GraphicsDeviceStrategy.CurrentContext.VertexTextures).Strategy.Dirty(0);
+            ((IPlatformTextureCollection)base.GraphicsDeviceStrategy.CurrentContext.Textures).Strategy.Dirty(0);
+            GL.ActiveTexture(WebGLTextureUnit.TEXTURE0);
+            GL.BindTexture(WebGLTextureTarget.TEXTURE_2D, _glTexture);
+            GL.PixelStore(WebGLPixelParameter.UNPACK_ALIGNMENT, 4);
+            GL.PixelStore(WebGLPixelParameter.UNPACK_FLIP_Y_WEBGL, options.FlipY ? 1 : 0);
+            GL.PixelStore(WebGLPixelParameter.UNPACK_PREMULTIPLY_ALPHA_WEBGL, options.PremultiplyAlpha ? 1 : 0);
+            GL.PixelStore(WebGLPixelParameter.UNPACK_COLORSPACE_CONVERSION_WEBGL,
+                options.ColorSpaceConversion == WebGLCanvasColorSpaceConversion.None ? 0 : 0x9244);
+
+            try
+            {
+                CanvasTextureUploadInterop.Upload(((RenderingContext)GL).Uid, _glTexture.Uid, source.ElementId,
+                    options.UploadMode == WebGLCanvasUploadMode.TexImage2D ? 1 : 0);
+            }
+            finally
+            {
+                GL.PixelStore(WebGLPixelParameter.UNPACK_FLIP_Y_WEBGL, 0);
+                GL.PixelStore(WebGLPixelParameter.UNPACK_PREMULTIPLY_ALPHA_WEBGL, 0);
+                GL.PixelStore(WebGLPixelParameter.UNPACK_COLORSPACE_CONVERSION_WEBGL, 0x9244);
+                GL.PixelStore(WebGLPixelParameter.UNPACK_ALIGNMENT, 4);
+            }
+        }
